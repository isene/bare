#!/bin/bash
# bare plugin: :ask <question>
# Ask AI a question and get a conversational response.
#
# Setup:
#   1. Get an API key from https://platform.openai.com/api-keys
#   2. Store it in a file: echo "sk-..." > ~/.config/bare/openai_key
#   3. Or set the environment variable: export OPENAI_API_KEY="sk-..."
#   4. Copy this file to ~/.bare/plugins/ask and chmod +x it
#
# Usage:
#   :ask how do I find large files?
#   :ask what does the -R flag do in grep?

set -e

# Read API key
if [ -n "$OPENAI_API_KEY" ]; then
    API_KEY="$OPENAI_API_KEY"
elif [ -f "$HOME/.config/bare/openai_key" ]; then
    API_KEY=$(cat "$HOME/.config/bare/openai_key" | tr -d '\n')
elif [ -f "/home/.safe/openai.txt" ]; then
    API_KEY=$(cat "/home/.safe/openai.txt" | tr -d '\n')
else
    echo "No API key found. Set OPENAI_API_KEY or create ~/.config/bare/openai_key"
    exit 1
fi

QUESTION="$*"
if [ -z "$QUESTION" ]; then
    echo "Usage: :ask <question>"
    exit 1
fi

# Escape JSON
ESCAPED=$(echo "$QUESTION" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\n/\\n/g')

RESPONSE=$(curl -s https://api.openai.com/v1/chat/completions \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer $API_KEY" \
    -d "{
        \"model\": \"gpt-4o-mini\",
        \"temperature\": 0.3,
        \"messages\": [
            {\"role\": \"system\", \"content\": \"You are a helpful terminal assistant. Give concise, practical answers. Use examples when helpful. Keep responses under 10 lines.\"},
            {\"role\": \"user\", \"content\": \"$ESCAPED\"}
        ]
    }" 2>/dev/null)

# Extract content from JSON response (simple grep, no jq dependency)
echo "$RESPONSE" | grep -o '"content":"[^"]*"' | head -1 | sed 's/"content":"//;s/"$//' | sed 's/\\n/\n/g; s/\\"/"/g; s/\\\\/\\/g'
